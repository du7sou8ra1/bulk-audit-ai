# ---------------------------------------------------------------------------
# BulkAuditAI configuration
# Copy this file to `.env` and fill in your own values.
# Secrets are read from here and NEVER stored in SQLite or shown in full in UI.
# ---------------------------------------------------------------------------

# --- Chain access (READ-ONLY RPC only) -------------------------------------
# Any RPC that supports eth_call / eth_getStorageAt / eth_getCode / eth_getBalance.
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/REPLACE_ME
CHAIN=ethereum
# Optional per-chain RPCs for multi-chain scanning/monitoring (picked by chain name):
#   RPC_URL_BASE=https://base-mainnet.g.alchemy.com/v2/REPLACE_ME
#   RPC_URL_ARBITRUM=...   RPC_URL_OPTIMISM=...   RPC_URL_POLYGON=...   RPC_URL_BSC=...

# --- Source/ABI fetching ----------------------------------------------------
ETHERSCAN_API_KEY=REPLACE_ME
# Etherscan v2 multichain base. The chainid is appended per-chain by the app.
ETHERSCAN_BASE_URL=https://api.etherscan.io/v2/api

# --- DeepSeek AI reviewer (OpenAI-compatible chat completions) --------------
# Default: DeepSeek's own API.
DEEPSEEK_API_KEY=REPLACE_ME
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
#
# To use OpenRouter instead (any OpenAI-compatible model), set:
#   DEEPSEEK_API_KEY=sk-or-v1-...                      # from https://openrouter.ai/keys
#   DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1
#   DEEPSEEK_MODEL=deepseek/deepseek-v4-pro            # or deepseek/deepseek-v4-flash, etc.

# --- Feature toggles --------------------------------------------------------
ENABLE_SLITHER=true
ENABLE_MYTHRIL=true
ENABLE_SEMGREP=true
ENABLE_FOUNDRY=false
ENABLE_DEEPSEEK=true

# --- Reasoning + validation layers (v0.3+) ---------------------------------
ENABLE_INVARIANT_REASONER=true   # LLM cross-function invariant hypotheses (needs DEEPSEEK key)
ENABLE_REFUTATION=true           # adversarial refutation of each candidate (needs DEEPSEEK key)
ENABLE_SOURCIFY=true             # Sourcify fallback when Etherscan source is unverified/missing
MAX_HYPOTHESES_PER_TARGET=8
ENABLE_FLASHLOAN_SIM=true        # fork oracle/donation manipulation sim (needs ENABLE_FOUNDRY + RPC)
MAX_SIMS_PER_TARGET=2

# --- Limits / timeouts (seconds) -------------------------------------------
MAX_PARALLEL_SCANS=2
MAX_PARALLEL_TARGETS=3
MYTHRIL_TIMEOUT=300
SLITHER_TIMEOUT=180
SEMGREP_TIMEOUT=120
FOUNDRY_TIMEOUT=300

# --- Server -----------------------------------------------------------------
# Bind address. Use 127.0.0.1 if you reach the app via an SSH tunnel (most
# secure — see README "Use it as a website on your PC"). Use 0.0.0.0 to expose
# it on the VPS network/public interface (then firewall the port + add auth).
HOST=0.0.0.0
# Fresh, uncommon port so it does not collide with services already on 8000.
PORT=8791
# Comma-separated allowed frontend origins for CORS (only needed in dev mode;
# single-port production serving is same-origin and needs none).
CORS_ORIGINS=http://localhost:5891,http://127.0.0.1:5891

# --- Monitoring ("before-drain") + alerting --------------------------------
ENABLE_MONITOR=false             # set true to auto-watch contract upgrades + new deploys
MONITOR_INTERVAL_SECONDS=300
MONITOR_SCAN_PROFILE=defi-deep
MAX_NEW_DEPLOYS_PER_CHECK=25
# Outbound webhook for alerts (Slack/Discord-compatible or generic JSON). Empty = alerts off.
ALERT_WEBHOOK_URL=

# --- Storage ----------------------------------------------------------------
DATABASE_URL=sqlite:///./bulkauditai.db
OUTPUT_DIR=./backend/outputs/scans
